# [Development] Environment Variables

# Application deployment base path (if deployed in subdirectory /admin, set to /admin/)
VITE_BASE_URL = /

# API request base path (set to / in development to use proxy, set to full backend address in production)
VITE_API_URL = /

# Proxy target address (Development environment forwards requests through Vite proxy to this address to resolve CORS issues)
VITE_API_PROXY_URL = http://localhost:8080

# Delete console
VITE_DROP_CONSOLE = false